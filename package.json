{
  "name": "pantograph",
  "version": "1.0.0",
  "description": "A fluid intrinsically-typed structure editor",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "purescript": "^0.15.16",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.5",
    "purs-backend-es": "^1.4.3",
    "spago": "^1.0.4"
  },
  "scripts": {
    "postinstall": "spago install",
    "clean": "rm -rf node_modules output .spago *.lock .cache",
    "clean-purscript": "rm -rf output .spago .psc-ide-port .psci_modules",
    "test": "npx spago test",
    "build-old": "npx spago build --purs-args \"--codegen=sourcemaps,js\"",
    "build-prod": "spago build --purs-args \"-o output-prod -g sourcemaps --json-errors\"",
    "bundle": "npm run build-prod && purs-backend-es bundle-app --main Main --minify --no-build --to dist/pantograph.js",
    "build-tutorial": "spago build && npx esbuild tutorial.js --bundle --outfile=dist/pantograph.js",
    "build-standalone": "spago build && npx esbuild standalone.js --bundle --outfile=dist/standalone/pantograph.js",
    "build-custom-language-standalone": "spago build && npx esbuild custom-language-standalone.js --bundle --outfile=dist/custom-language-standalone/pantograph.js",
    "build": "npm run build-tutorial && npm run build-standalone",
    "serve-tutorial": "npm run build-tutorial && npx http-server dist",
    "serve-standalone": "npm run build && npx http-server dist/standalone",
    "serve-custom-language-standalone": "npm run build && npx http-server dist/custom-language-standalone",
    "docs": "npm run build && rm -rf docs && cp -r dist docs",
    "publish": "npm run docs && git add . && git commit -m\"publish\" && git push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeprinz/pantograph.git"
  },
  "keywords": [
    "programm-language",
    "type-theory"
  ],
  "author": "Jacob Prinz, Henry Blanchette",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jeprinz/pantograph/issues"
  },
  "homepage": "https://github.com/jeprinz/pantograph#readme",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}